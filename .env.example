# ── Auth ──────────────────────────────────────────────────────────────────────
# Must match the TRANCHI_API_SECRET on the main app and tranchi-outbound-agent
TRANCHI_API_SECRET=dev-secret-change-me

# Webhook signing secret (HMAC SHA256) — set same value in lender partner portal
LENDER_WEBHOOK_SECRET=

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=   # Optional — used as fallback if Anthropic call fails

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path for local dev. On Render, set to /opt/render/project/data/loan_agents.db
DB_PATH=data/loan_agents.db

# ── Tranchi Outbound Agent ────────────────────────────────────────────────────
# Base URL of the deployed outbound-agent service
OUTBOUND_AGENT_URL=https://tranchi-outbound-agent.onrender.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5010
FLASK_ENV=development

# ── AWS S3 (intake document uploads) ─────────────────────────────────────────
# Bucket borrower docs are stored in via presigned PUT URLs.
# Without AWS_S3_BUCKET set, the intake routes return 503 (configured-off mode).
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_KEY_PREFIX=intake/
# Credentials follow standard boto3 discovery: env vars, ~/.aws/credentials,
# or instance role. Set only if you're not using ambient creds.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Arive LOS Integration (via Zapier) ───────────────────────────────────────
# HMAC secret for verifying inbound Arive webhooks (set in Arive webhook config)
ARIVE_WEBHOOK_SECRET=

# Zapier webhook URLs — one per outbound event type.
# Leave empty in dev; fire_zap() will no-op gracefully.
# Get each URL from: Zapier → New Zap → Trigger: Webhooks by Zapier → Catch Hook
ZAPIER_HOOK_PREQUAL_CREATED=
ZAPIER_HOOK_APPLICATION_SUBMITTED=
ZAPIER_HOOK_DOCUMENTS_UPLOADED=
ZAPIER_HOOK_READY_FOR_UNDERWRITING=
ZAPIER_HOOK_LENDER_ROUTED=
ZAPIER_HOOK_APPROVED=
ZAPIER_HOOK_DECLINED=
ZAPIER_HOOK_FUNDED=

# Fires when a pre-qualification letter is auto-generated.
# Wire a Zap: Webhook trigger → Gmail send-email with the inline base64 PDF attachment.
# Payload includes: letter_id, prequal_id, borrower_name, borrower_email, max_pp_low,
# max_pp_high, rate_low_pct, rate_high_pct, down_pct_low, issued_at, expires_at, pdf_base64.
ZAPIER_HOOK_PREQUAL_LETTER_SENT=

# ── Pre-Qualification Letter Signer ──────────────────────────────────────────
# Override the defaults baked into prequal_letter.py if needed.
LO_FIRM_NAME=Munoz, Ghezlan & Co., Ltd.
LO_FIRM_ADDR_1=99 Wall Street, Suite 4041
LO_FIRM_ADDR_2=New York, NY 10005
LO_SIGNER_NAME=Marc Munoz
LO_SIGNER_TITLE=Senior Loan Officer
LO_SIGNER_EMAIL=marc@munoz.ltd
LO_SIGNER_PHONE=(917) 981-0032
