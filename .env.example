# ── Auth ──────────────────────────────────────────────────────────────────────
# Must match the TRANCHI_API_SECRET on the main app and tranchi-outbound-agent
TRANCHI_API_SECRET=dev-secret-change-me

# Webhook signing secret (HMAC SHA256) — set same value in lender partner portal
LENDER_WEBHOOK_SECRET=

# Typeform webhook secret — set the SAME value in the Typeform "Connect → Webhooks"
# panel for prequal.typeform.com/qualification. Typeform signs request bodies with
# HMAC SHA256 and sends the digest as `Typeform-Signature: sha256=<base64>`.
# Leave empty in dev to bypass signature verification (the handler still logs a warning).
TYPEFORM_WEBHOOK_SECRET=

# Typeform Personal Access Token — required to DOWNLOAD borrower-uploaded files
# (the asset_statement_*_url answers point at api.typeform.com/responses/files/...,
# which 401s without auth). Create at https://admin.typeform.com/account#/section/tokens.
# Read scope is sufficient. Without this, the prequal-letter autofire OCR step will
# 401 on every download and the letter will be skipped.
TYPEFORM_ACCESS_TOKEN=

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=   # Optional — used as fallback if Anthropic call fails

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite path for local dev. On Render, set to /opt/render/project/data/loan_agents.db
DB_PATH=data/loan_agents.db

# ── Tranchi Outbound Agent ────────────────────────────────────────────────────
# Base URL of the deployed outbound-agent service
OUTBOUND_AGENT_URL=https://tranchi-outbound-agent.onrender.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5010
FLASK_ENV=development

# ── AWS S3 (intake document uploads) ─────────────────────────────────────────
# Bucket borrower docs are stored in via presigned PUT URLs.
# Without AWS_S3_BUCKET set, the intake routes return 503 (configured-off mode).
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_KEY_PREFIX=intake/
# Credentials follow standard boto3 discovery: env vars, ~/.aws/credentials,
# or instance role. Set only if you're not using ambient creds.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Arive LOS Integration (via Zapier) ───────────────────────────────────────
# HMAC secret for verifying inbound Arive webhooks (set in Arive webhook config)
ARIVE_WEBHOOK_SECRET=

# Zapier webhook URLs — one per outbound event type.
# Leave empty in dev; fire_zap() will no-op gracefully.
# Get each URL from: Zapier → New Zap → Trigger: Webhooks by Zapier → Catch Hook
ZAPIER_HOOK_PREQUAL_CREATED=
ZAPIER_HOOK_APPLICATION_SUBMITTED=
ZAPIER_HOOK_DOCUMENTS_UPLOADED=
ZAPIER_HOOK_READY_FOR_UNDERWRITING=
ZAPIER_HOOK_LENDER_ROUTED=
ZAPIER_HOOK_APPROVED=
ZAPIER_HOOK_DECLINED=
ZAPIER_HOOK_FUNDED=
ZAPIER_HOOK_BORROWER_INTAKE_CREATED=

# Fires when a pre-qualification letter is auto-generated.
# Wire a Zap: Webhook trigger → Gmail send-email with the inline base64 PDF attachment.
# Payload includes: letter_id, prequal_id, borrower_name, borrower_email, max_pp_low,
# max_pp_high, rate_low_pct, rate_high_pct, down_pct_low, issued_at, expires_at, pdf_base64.
ZAPIER_HOOK_PREQUAL_LETTER_SENT=

# ── Pre-Qualification Letter Signer ──────────────────────────────────────────
# Override the defaults baked into prequal_letter.py if needed.
LO_FIRM_NAME=Munoz, Ghezlan & Co., Ltd.
LO_FIRM_ADDR_1=99 Wall Street, Suite 4041
LO_FIRM_ADDR_2=New York, NY 10005
LO_SIGNER_NAME=Marc Munoz
LO_SIGNER_TITLE=Senior Loan Officer
LO_SIGNER_EMAIL=marc@munoz.ltd
LO_SIGNER_PHONE=(917) 981-0032

# ── Zapier MCP (server-side; preferred path for Gmail send) ──────────────────
# The full SSE endpoint URL (e.g. https://mcp.zapier.com/api/v1/mcp/<id>/sse).
# When set, prequal letters are sent via Zapier MCP → Gmail Send directly from
# the server. When unset, falls back to the ZAPIER_HOOK_PREQUAL_LETTER_SENT
# webhook (above).
ZAPIER_MCP_ENDPOINT=
ZAPIER_MCP_API_KEY=
ZAPIER_MCP_TIMEOUT_S=30

# ── Self-hosted PDF endpoint ─────────────────────────────────────────────────
# Public base URL of this service (used to build attachment URLs for emails
# when S3 isn't configured). Render auto-injects RENDER_EXTERNAL_URL but we
# accept PUBLIC_BASE_URL explicitly for portability.
PUBLIC_BASE_URL=

# ── Inbound email attachment (Zapier-fired webhook) ──────────────────────────
# Shared secret protecting POST /api/intake/inbound-email-attachment.
# Configure your Zap to send this in the Authorization: Bearer header,
# the X-Zapier-Secret header, or as a ?secret= query param.
# Falls back to TRANCHI_API_SECRET if unset — but set it explicitly in prod.
ZAPIER_INBOUND_SECRET=

# ── Deal-flow service URL (for PSA → TX handoff) ─────────────────────────────
DEAL_FLOW_URL=https://tranchi-deal-flow-agents.onrender.com

# ── External POS / 1003 application URL ──────────────────────────────────────
# Public URL where the borrower self-registers and fills out the URLA Form 1003.
# Emailed to the borrower automatically when their PSA arrives + classifies as
# a purchase_contract. Defaults to the Munoz firm's my1003app POS.
LOAN_APPLICATION_URL=https://2589631.my1003app.com/0/register
